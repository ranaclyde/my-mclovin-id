---
interface Props {
  class?: string
}
const { class: className } = Astro.props
---

<!-- USA flag: 13 stripes + blue canton -->
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 20 14"
  class:list={['rounded-sm', className]}
  aria-hidden="true"
>
  <!-- Red base -->
  <rect width="20" height="14" fill="#B22234" rx="1" />
  <!-- White stripes -->
  <rect y="1.077" width="20" height="1.077" fill="white" />
  <rect y="3.23"  width="20" height="1.077" fill="white" />
  <rect y="5.385" width="20" height="1.077" fill="white" />
  <rect y="7.538" width="20" height="1.077" fill="white" />
  <rect y="9.692" width="20" height="1.077" fill="white" />
  <rect y="11.846" width="20" height="1.077" fill="white" />
  <!-- Blue canton -->
  <rect width="8" height="7.538" fill="#3C3B6E" rx="1" ry="0" />
  <!-- Stars (simplified dots) -->
  <g fill="white" font-size="1.4">
    <!-- Row 1: 6 stars -->
    <circle cx="1.1" cy="1.1" r="0.55" />
    <circle cx="2.8" cy="1.1" r="0.55" />
    <circle cx="4.5" cy="1.1" r="0.55" />
    <circle cx="6.2" cy="1.1" r="0.55" />
    <!-- Row 2: 5 stars (offset) -->
    <circle cx="1.95" cy="2.3" r="0.55" />
    <circle cx="3.65" cy="2.3" r="0.55" />
    <circle cx="5.35" cy="2.3" r="0.55" />
    <!-- Row 3 -->
    <circle cx="1.1" cy="3.5" r="0.55" />
    <circle cx="2.8" cy="3.5" r="0.55" />
    <circle cx="4.5" cy="3.5" r="0.55" />
    <circle cx="6.2" cy="3.5" r="0.55" />
    <!-- Row 4 -->
    <circle cx="1.95" cy="4.7" r="0.55" />
    <circle cx="3.65" cy="4.7" r="0.55" />
    <circle cx="5.35" cy="4.7" r="0.55" />
    <!-- Row 5 -->
    <circle cx="1.1" cy="5.9" r="0.55" />
    <circle cx="2.8" cy="5.9" r="0.55" />
    <circle cx="4.5" cy="5.9" r="0.55" />
    <circle cx="6.2" cy="5.9" r="0.55" />
  </g>
</svg>
