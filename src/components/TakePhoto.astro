---
import Input from '@/components/ui/Input.astro'
import Check from '@/icons/check.astro'
import Reload from '@/icons/reload.astro'
import Close from '@/icons/close.astro'
import ArrowFoward from '@/icons/arrowFoward.astro'
---

<Input
  id="upload"
  type="file"
  label="Subí tu foto"
  class="mb-5"
  accept="image/png, image/jpeg, image/webp"
  placeholder="Seleccioná una imagen para tu ID"
/>

<dialog id="cropImgModal" class="crop-dialog">
  <!-- Gold accent bar -->
  <div class="h-1 w-full bg-gradient-to-r from-amber-500 via-yellow-400 to-amber-500 rounded-t-xl"></div>

  <!-- Header -->
  <div class="flex items-center justify-between px-5 py-4 border-b border-hawaii-steel/60">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-amber-500/15 border border-amber-500/30 flex items-center justify-center">
        <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <div>
        <h3 id="modalTitle" class="text-base font-bold text-white">Recortá tu foto</h3>
        <p id="modalSubtitle" class="text-xs text-slate-400">Ajustá el encuadre para tu ID</p>
      </div>
    </div>
    <button
      id="closeModal"
      type="button"
      class="w-8 h-8 rounded-lg inline-flex items-center justify-center text-slate-500 hover:bg-hawaii-steel/60 hover:text-white transition-colors"
    >
      <Close />
      <span class="sr-only">Cerrar</span>
    </button>
  </div>

  <!-- Body -->
  <div class="px-5 py-5 space-y-4">

    <!-- Croppie -->
    <div id="cropView">
      <div id="croppieContainer"></div>
      <p class="text-xs text-slate-500 text-center mt-2">Arrastrá y hacé zoom para ajustar</p>
    </div>

    <!-- Preview (oculto hasta que se recorta) -->
    <div id="previewView" class="hidden flex-col items-center gap-3">
      <img
        id="croppedImage"
        alt="Imagen recortada"
        width="170"
        height="208"
        class="rounded-lg border-2 border-amber-500/50 block"
      />
      <p class="text-xs text-slate-400">¿Quedó bien? Usá esta foto o recortá de nuevo</p>
    </div>

    <!-- Botones -->
    <div class="flex gap-3">
      <button
        id="btnCrop"
        type="button"
        class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-amber-500 hover:bg-amber-600 text-hawaii-navy font-semibold text-sm transition-all hover:scale-[1.02] active:scale-[0.98]"
      >
        <Check class="w-4 h-4" />
        Recortar foto
      </button>

      <button
        id="resetCrop"
        type="button"
        class="hidden flex-1 items-center justify-center gap-2 px-4 py-2.5 rounded-lg border border-hawaii-steel hover:border-amber-500/40 hover:bg-hawaii-steel/40 text-slate-300 hover:text-white font-medium text-sm transition-all hover:scale-[1.02] active:scale-[0.98]"
      >
        <Reload class="w-4 h-4" />
        Recortar de nuevo
      </button>

      <button
        id="next"
        type="button"
        class="hidden flex-1 items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-amber-500 hover:bg-amber-600 text-hawaii-navy font-semibold text-sm transition-all hover:scale-[1.02] active:scale-[0.98]"
      >
        Usar esta foto
        <ArrowFoward class="w-4 h-4" />
      </button>
    </div>

  </div>
</dialog>

<script>
  import Croppie from 'croppie'
  import { $ } from '@/utils/domSelector'

  const dialog = $<HTMLDialogElement>('#cropImgModal')
  const $upload = $<HTMLInputElement>('#upload')
  const $imgContainer = $('#croppieContainer') as HTMLElement
  const $croppedImage = $<HTMLImageElement>('#croppedImage')
  const $cropView = $('#cropView') as HTMLElement
  const $previewView = $('#previewView') as HTMLElement
  const $btnCrop = $<HTMLButtonElement>('#btnCrop')
  const $btnReset = $<HTMLButtonElement>('#resetCrop')
  const $btnNext = $<HTMLButtonElement>('#next')
  const $closeBtn = $<HTMLButtonElement>('#closeModal')
  const $modalTitle = $('#modalTitle') as HTMLElement
  const $modalSubtitle = $('#modalSubtitle') as HTMLElement

  const croppie = new Croppie($imgContainer, {
    viewport: { width: 170.6, height: 208.3, type: 'square' },
    boundary: { width: 210, height: 200 },
    enabledResize: true,
  })

  function showCropView() {
    $cropView.classList.remove('hidden')
    $previewView.classList.add('hidden')
    $previewView.classList.remove('flex')
    $btnCrop.classList.remove('hidden')
    $btnReset.classList.add('hidden')
    $btnReset.classList.remove('flex')
    $btnNext.classList.add('hidden')
    $btnNext.classList.remove('flex')
    $modalTitle.textContent = 'Recortá tu foto'
    $modalSubtitle.textContent = 'Ajustá el encuadre para tu ID'
  }

  function showPreviewView() {
    $cropView.classList.add('hidden')
    $previewView.classList.remove('hidden')
    $previewView.classList.add('flex')
    $btnCrop.classList.add('hidden')
    $btnReset.classList.remove('hidden')
    $btnReset.classList.add('flex')
    $btnNext.classList.remove('hidden')
    $btnNext.classList.add('flex')
    $modalTitle.textContent = 'Confirmá tu foto'
    $modalSubtitle.textContent = 'Así va a aparecer en tu ID'
  }

  $upload?.addEventListener('change', (e) => {
    const target = e.target as HTMLInputElement
    const file = (target.files as FileList)[0]
    const allowed = ['image/png', 'image/jpeg', 'image/webp']

    if (!allowed.includes(file.type)) return

    showCropView()
    dialog.showModal()

    const reader = new FileReader()
    reader.onload = (ev) => {
      croppie.bind({ url: ev.target?.result as string })
    }
    reader.readAsDataURL(file)
  })

  function closeDialog() {
    if (!$croppedImage.src || $croppedImage.src === window.location.href) {
      $upload.value = ''
    }
    dialog.close()
  }

  $closeBtn?.addEventListener('click', closeDialog)
  $btnNext?.addEventListener('click', closeDialog)

  // Cerrar al hacer click en el backdrop (área fuera del dialog)
  dialog?.addEventListener('click', (e) => {
    const rect = dialog.getBoundingClientRect()
    const isInside =
      e.clientX >= rect.left &&
      e.clientX <= rect.right &&
      e.clientY >= rect.top &&
      e.clientY <= rect.bottom
    if (!isInside) closeDialog()
  })

  // Escape ya es manejado nativamente por <dialog>
  dialog?.addEventListener('cancel', () => {
    if (!$croppedImage.src || $croppedImage.src === window.location.href) {
      $upload.value = ''
    }
  })

  $btnCrop?.addEventListener('click', () => {
    croppie.result('canvas').then((result: string) => {
      $croppedImage.src = result
      showPreviewView()
    })
  })

  $btnReset?.addEventListener('click', showCropView)
</script>

<style is:global>
  @import url('croppie/croppie.css');

  .crop-dialog {
    background: #0d1528;
    border: 1px solid #1e3a5f;
    border-radius: 0.75rem;
    padding: 0;
    width: 100%;
    max-width: 420px;
    color: white;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.8);
  }

  .crop-dialog::backdrop {
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
  }

  /* Croppie dark theme */
  .crop-dialog .cr-viewport {
    border: 2px solid rgba(245, 158, 11, 0.7) !important;
    box-shadow: 0 0 0 2000px rgba(6, 11, 22, 0.8) !important;
  }
  .crop-dialog .cr-slider {
    accent-color: #f59e0b;
  }
</style>
