---
import Check from '@/icons/check.astro'
import Reload from '@/icons/reload.astro'
import Close from '@/icons/close.astro'
import ArrowFoward from '@/icons/arrowFoward.astro'
import type { PhotoTranslations } from '@/i18n/translations'

interface Props {
  t: PhotoTranslations
}

const { t } = Astro.props
---

<div class="mb-5">
  <p class="block mb-2 text-sm font-medium text-white">{t.label}</p>
  <div id="photoButtonsRow" class="flex gap-2">
    <label
      for="upload"
      id="uploadBtn"
      class="flex flex-1 items-center justify-center gap-2 px-4 py-2.5 rounded-lg border border-hawaii-steel hover:border-amber-500/40 hover:bg-hawaii-steel/40 text-slate-300 hover:text-white font-medium text-sm transition-all hover:scale-[1.02] active:scale-[0.98] cursor-pointer min-w-0"
    >
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
      </svg>
      <span id="uploadLabel" class="truncate">{t.placeholder}</span>
    </label>
    <input
      id="upload"
      type="file"
      accept="image/png, image/jpeg, image/webp"
      class="sr-only"
    />

    <button
      id="cameraBtn"
      type="button"
      class="hidden shrink-0 items-center justify-center gap-2 px-4 py-2.5 rounded-lg border border-hawaii-steel hover:border-amber-500/40 hover:bg-hawaii-steel/40 text-slate-300 hover:text-white font-medium text-sm transition-all hover:scale-[1.02] active:scale-[0.98]"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.069A1 1 0 0121 8.882v6.236a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z" />
      </svg>
      {t.cameraBtn}
    </button>
  </div>
</div>

<dialog
  id="cropImgModal"
  class="crop-dialog"
  data-crop-title={t.cropTitle}
  data-crop-subtitle={t.cropSubtitle}
  data-confirm-title={t.confirmTitle}
  data-confirm-subtitle={t.confirmSubtitle}
  data-camera-title={t.cameraTitle}
  data-camera-subtitle={t.cameraSubtitle}
>
  <!-- Gold accent bar -->
  <div class="h-1 w-full bg-gradient-to-r from-amber-500 via-yellow-400 to-amber-500 rounded-t-xl"></div>

  <!-- Header -->
  <div class="flex items-center justify-between px-5 py-4 border-b border-hawaii-steel/60">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-amber-500/15 border border-amber-500/30 flex items-center justify-center">
        <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <div>
        <h3 id="modalTitle" class="text-base font-bold text-white">{t.cropTitle}</h3>
        <p id="modalSubtitle" class="text-xs text-slate-400">{t.cropSubtitle}</p>
      </div>
    </div>
    <button
      id="closeModal"
      type="button"
      class="w-8 h-8 rounded-lg inline-flex items-center justify-center text-slate-500 hover:bg-hawaii-steel/60 hover:text-white transition-colors"
    >
      <Close />
      <span class="sr-only">{t.close}</span>
    </button>
  </div>

  <!-- Body -->
  <div class="px-5 py-5 space-y-4">

    <!-- Camera view -->
    <div id="cameraView" class="hidden">
      <video
        id="cameraStream"
        autoplay
        playsinline
        muted
        class="w-full rounded-lg border border-hawaii-steel/60 bg-black"
        style="max-height: 260px; object-fit: cover;"
      ></video>
      <p class="text-xs text-slate-500 text-center mt-2">{t.cameraSubtitle}</p>
    </div>

    <!-- Croppie -->
    <div id="cropView">
      <div id="croppieContainer"></div>
      <p class="text-xs text-slate-500 text-center mt-2">{t.cropHint}</p>
    </div>

    <!-- Preview (oculto hasta que se recorta) -->
    <div id="previewView" class="hidden flex-col items-center gap-3">
      <img
        id="croppedImage"
        alt="Imagen recortada"
        width="170"
        height="208"
        class="rounded-lg border-2 border-amber-500/50 block"
      />
      <p class="text-xs text-slate-400">{t.confirmQuestion}</p>
    </div>

    <!-- Botones -->
    <div class="flex gap-3">
      <button
        id="btnCapture"
        type="button"
        class="hidden flex-1 items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-amber-500 hover:bg-amber-600 text-hawaii-navy font-semibold text-sm transition-all hover:scale-[1.02] active:scale-[0.98]"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="3" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
        </svg>
        {t.cameraCaptureBtn}
      </button>

      <button
        id="btnCrop"
        type="button"
        class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-amber-500 hover:bg-amber-600 text-hawaii-navy font-semibold text-sm transition-all hover:scale-[1.02] active:scale-[0.98]"
      >
        <Check class="w-4 h-4" />
        {t.cropBtn}
      </button>

      <button
        id="resetCrop"
        type="button"
        class="hidden flex-1 items-center justify-center gap-2 px-4 py-2.5 rounded-lg border border-hawaii-steel hover:border-amber-500/40 hover:bg-hawaii-steel/40 text-slate-300 hover:text-white font-medium text-sm transition-all hover:scale-[1.02] active:scale-[0.98]"
      >
        <Reload class="w-4 h-4" />
        {t.recropBtn}
      </button>

      <button
        id="next"
        type="button"
        class="hidden flex-1 items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-amber-500 hover:bg-amber-600 text-hawaii-navy font-semibold text-sm transition-all hover:scale-[1.02] active:scale-[0.98]"
      >
        {t.useBtn}
        <ArrowFoward class="w-4 h-4" />
      </button>
    </div>

  </div>
</dialog>

<script>
  import Croppie from 'croppie'
  import { $ } from '@/utils/domSelector'

  const dialog = $<HTMLDialogElement>('#cropImgModal')
  const $upload = $<HTMLInputElement>('#upload')
  const $imgContainer = $('#croppieContainer') as HTMLElement
  const $croppedImage = $<HTMLImageElement>('#croppedImage')
  const $cropView = $('#cropView') as HTMLElement
  const $cameraView = $('#cameraView') as HTMLElement
  const $cameraVideo = $<HTMLVideoElement>('#cameraStream')
  const $previewView = $('#previewView') as HTMLElement
  const $btnCrop = $<HTMLButtonElement>('#btnCrop')
  const $btnCapture = $<HTMLButtonElement>('#btnCapture')
  const $btnReset = $<HTMLButtonElement>('#resetCrop')
  const $btnNext = $<HTMLButtonElement>('#next')
  const $closeBtn = $<HTMLButtonElement>('#closeModal')
  const $cameraBtn = $<HTMLButtonElement>('#cameraBtn')
  const $uploadLabel = $('#uploadLabel') as HTMLElement
  const $modalTitle = $('#modalTitle') as HTMLElement
  const $modalSubtitle = $('#modalSubtitle') as HTMLElement
  const uploadPlaceholder = $uploadLabel?.textContent ?? ''

  let cameraStream: MediaStream | null = null

  const croppie = new Croppie($imgContainer, {
    viewport: { width: 170.6, height: 208.3, type: 'square' },
    boundary: { width: 210, height: 200 },
    enabledResize: true,
  })

  // Detect camera and show button if available
  async function detectCamera() {
    if (!navigator.mediaDevices?.enumerateDevices) return
    try {
      const devices = await navigator.mediaDevices.enumerateDevices()
      if (devices.some((d) => d.kind === 'videoinput')) {
        $cameraBtn?.classList.remove('hidden')
        $cameraBtn?.classList.add('flex')
      }
    } catch {
      // silently ignore if permissions API not available
    }
  }

  detectCamera()

  function stopStream() {
    if (cameraStream) {
      cameraStream.getTracks().forEach((t) => t.stop())
      cameraStream = null
    }
    if ($cameraVideo) $cameraVideo.srcObject = null
  }

  function showCameraView() {
    $cameraView.classList.remove('hidden')
    $cropView.classList.add('hidden')
    $previewView.classList.add('hidden')
    $previewView.classList.remove('flex')
    $btnCapture.classList.remove('hidden')
    $btnCapture.classList.add('flex')
    $btnCrop.classList.add('hidden')
    $btnReset.classList.add('hidden')
    $btnReset.classList.remove('flex')
    $btnNext.classList.add('hidden')
    $btnNext.classList.remove('flex')
    $modalTitle.textContent = dialog.dataset.cameraTitle ?? ''
    $modalSubtitle.textContent = dialog.dataset.cameraSubtitle ?? ''
  }

  function showCropView() {
    $cameraView.classList.add('hidden')
    $cropView.classList.remove('hidden')
    $previewView.classList.add('hidden')
    $previewView.classList.remove('flex')
    $btnCapture.classList.add('hidden')
    $btnCapture.classList.remove('flex')
    $btnCrop.classList.remove('hidden')
    $btnCrop.classList.add('flex')
    $btnReset.classList.add('hidden')
    $btnReset.classList.remove('flex')
    $btnNext.classList.add('hidden')
    $btnNext.classList.remove('flex')
    $modalTitle.textContent = dialog.dataset.cropTitle ?? ''
    $modalSubtitle.textContent = dialog.dataset.cropSubtitle ?? ''
  }

  function showPreviewView() {
    $cameraView.classList.add('hidden')
    $cropView.classList.add('hidden')
    $previewView.classList.remove('hidden')
    $previewView.classList.add('flex')
    $btnCapture.classList.add('hidden')
    $btnCapture.classList.remove('flex')
    $btnCrop.classList.add('hidden')
    $btnCrop.classList.remove('flex')
    $btnReset.classList.remove('hidden')
    $btnReset.classList.add('flex')
    $btnNext.classList.remove('hidden')
    $btnNext.classList.add('flex')
    $modalTitle.textContent = dialog.dataset.confirmTitle ?? ''
    $modalSubtitle.textContent = dialog.dataset.confirmSubtitle ?? ''
  }

  $upload?.addEventListener('change', (e) => {
    const target = e.target as HTMLInputElement
    const file = (target.files as FileList)[0]
    const allowed = ['image/png', 'image/jpeg', 'image/webp']

    if (!allowed.includes(file.type)) return

    if ($uploadLabel) $uploadLabel.textContent = file.name
    showCropView()
    dialog.showModal()

    const reader = new FileReader()
    reader.onload = (ev) => {
      croppie.bind({ url: ev.target?.result as string })
    }
    reader.readAsDataURL(file)
  })

  $cameraBtn?.addEventListener('click', async () => {
    $upload.value = ''
    if ($uploadLabel) $uploadLabel.textContent = uploadPlaceholder
    showCameraView()
    dialog.showModal()
    try {
      cameraStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' } })
      $cameraVideo.srcObject = cameraStream
    } catch {
      closeDialog()
    }
  })

  $btnCapture?.addEventListener('click', () => {
    const canvas = document.createElement('canvas')
    canvas.width = $cameraVideo.videoWidth
    canvas.height = $cameraVideo.videoHeight
    canvas.getContext('2d')?.drawImage($cameraVideo, 0, 0)
    const dataUrl = canvas.toDataURL('image/jpeg')
    stopStream()
    showCropView()
    croppie.bind({ url: dataUrl })
  })

  function closeDialog() {
    stopStream()
    if (!$croppedImage.src || $croppedImage.src === window.location.href) {
      $upload.value = ''
      if ($uploadLabel) $uploadLabel.textContent = uploadPlaceholder
    }
    dialog.close()
  }

  $closeBtn?.addEventListener('click', closeDialog)
  $btnNext?.addEventListener('click', closeDialog)

  // Cerrar al hacer click en el backdrop (área fuera del dialog)
  dialog?.addEventListener('click', (e) => {
    const rect = dialog.getBoundingClientRect()
    const isInside =
      e.clientX >= rect.left &&
      e.clientX <= rect.right &&
      e.clientY >= rect.top &&
      e.clientY <= rect.bottom
    if (!isInside) closeDialog()
  })

  // Escape ya es manejado nativamente por <dialog>
  dialog?.addEventListener('cancel', () => {
    stopStream()
    if (!$croppedImage.src || $croppedImage.src === window.location.href) {
      $upload.value = ''
      if ($uploadLabel) $uploadLabel.textContent = uploadPlaceholder
    }
  })

  $btnCrop?.addEventListener('click', () => {
    croppie.result('canvas').then((result: string) => {
      $croppedImage.src = result
      showPreviewView()
    })
  })

  $btnReset?.addEventListener('click', showCropView)
</script>

<style is:global>
  @import url('croppie/croppie.css');

  .crop-dialog {
    background: #0d1528;
    border: 1px solid #1e3a5f;
    border-radius: 0.75rem;
    padding: 0;
    width: 100%;
    max-width: 420px;
    color: white;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.8);
  }

  .crop-dialog::backdrop {
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
  }

  /* Croppie dark theme */
  .crop-dialog .cr-viewport {
    border: 2px solid rgba(245, 158, 11, 0.7) !important;
    box-shadow: 0 0 0 2000px rgba(6, 11, 22, 0.8) !important;
  }
  .crop-dialog .cr-slider {
    accent-color: #f59e0b;
  }
</style>
