---
import Button from '@/components/ui/Button.astro'
---

<nav class="border-b border-hawaii-steel bg-hawaii-dark px-4 md:px-6">
  <div
    class="mx-auto w-full max-w-screen-lg flex flex-wrap items-center justify-between py-4"
  >
    <div class="flex items-center space-x-3 rtl:space-x-reverse">
      <img src="/images/logo.webp" class="h-8" alt="McLovin Logo" />
      <span class="text-2xl font-semibold whitespace-nowrap text-hawaii-gold-light"
        >My McLovin ID</span
      >
    </div>
    <div class="flex md:order-2 space-x-3 md:space-x-0 rtl:space-x-reverse">
      <a href="#createid-section">
        <Button>Get Started</Button>
      </a>
    </div>
  </div>
</nav>
