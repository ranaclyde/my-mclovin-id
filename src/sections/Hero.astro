---
import Button from '@/components/ui/Button.astro'
import ArrowFoward from '@/icons/arrowFoward.astro'
---

<section class="bg-hawaii-dark py-16 md:py-24">
  <div class="mx-auto w-full max-w-screen-lg px-4 md:px-6">
    <div class="flex flex-col items-center gap-10 md:flex-row md:items-center md:justify-between">

      <!-- Left: Text -->
      <div class="text-center md:text-left md:max-w-lg">
        <span class="inline-block text-xs tracking-[0.3em] uppercase text-hawaii-blue-light border border-hawaii-steel rounded-full px-3 py-1 mb-4">
          Estado de Hawaii
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-hawaii-gold-light leading-tight">
          El ID más famoso del cine
        </h1>
        <p class="text-slate-300 text-base md:text-lg mt-4 mb-8">
          Crea tu propia versión del icónico documento de identidad de Fogell,
          el personaje más memorable de Superbad.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start">
          <a href="#createid-section">
            <Button size="lg" class="w-full sm:w-auto">
              Crear mi ID
              <ArrowFoward class="w-5 h-5" />
            </Button>
          </a>
          <a href="#about">
            <Button size="lg" color="info" variant="outlined" class="w-full sm:w-auto">
              Ver la escena
            </Button>
          </a>
        </div>
      </div>

      <!-- Right: ID preview -->
      <div class="w-full md:w-auto flex justify-center">
        <div class="relative">
          <div class="absolute inset-0 bg-amber-400 blur-2xl opacity-20 rounded-xl"></div>
          <img
            src="/images/mclovin-empty-id.webp"
            alt="McLovin ID de Hawaii"
            class="relative z-10 w-full max-w-sm md:max-w-md rounded-xl shadow-2xl shadow-amber-900/30 border border-hawaii-steel rotate-[-2deg]"
          />
        </div>
      </div>

    </div>
  </div>
</section>
