---
import type { AboutTranslations } from '@/i18n/translations'

interface Props {
  t: AboutTranslations
}

const { t } = Astro.props
---

<section id="about" class="bg-hawaii-card py-16">
  <div class="mx-auto w-full max-w-screen-lg px-4 md:px-6">

    <!-- Header -->
    <div data-animate class="opacity-0 animate-fade-in text-center mb-12">
      <span class="inline-block text-xs tracking-[0.3em] uppercase text-hawaii-blue-light border border-hawaii-steel rounded-full px-3 py-1 mb-4">
        {t.badge}
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-hawaii-gold-light mt-3">
        {t.title}
      </h2>
    </div>

    <!-- Content grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">

      <!-- Left: text -->
      <div data-animate class="opacity-0 animate-slide-up">
        <p class="text-slate-300 text-base leading-relaxed mb-4" set:html={t.paragraph1} />
        <p class="text-slate-300 text-base leading-relaxed mb-6" set:html={t.paragraph2} />

        <!-- Stats -->
        <div class="flex gap-8 mt-6">
          <div class="text-center">
            <span class="block text-2xl font-black text-amber-400">2007</span>
            <span class="text-xs text-slate-500 uppercase tracking-wider">{t.year}</span>
          </div>
          <div class="text-center">
            <span class="block text-2xl font-black text-amber-400">Christopher Mintz-Plasse</span>
            <span class="text-xs text-slate-500 uppercase tracking-wider">{t.actor}</span>
          </div>
        </div>
      </div>

      <!-- Right: YouTube embed -->
      <div data-animate class="opacity-0 animate-scale-in relative aspect-video rounded-xl overflow-hidden border border-hawaii-steel shadow-xl" style="animation-delay: 200ms">
        <iframe
          src={t.videoUrl}
          title={t.videoTitle}
          class="w-full h-full"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>

    </div>
  </div>
</section>
