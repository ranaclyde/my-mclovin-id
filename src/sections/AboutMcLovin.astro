---
import type { AboutTranslations } from '@/i18n/translations'

interface Props {
  t: AboutTranslations
}

const { t } = Astro.props

const videoId = t.videoUrl.split('/embed/')[1]?.split('?')[0] ?? ''
const thumbnailUrl = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`
---

<section id="about" class="bg-hawaii-card py-16">
  <div class="mx-auto w-full max-w-screen-lg px-4 md:px-6">

    <!-- Header -->
    <div data-animate class="opacity-0 animate-fade-in text-center mb-12">
      <span class="inline-block text-xs tracking-[0.3em] uppercase text-hawaii-blue-light border border-hawaii-steel rounded-full px-3 py-1 mb-4">
        {t.badge}
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-hawaii-gold-light mt-3">
        {t.title}
      </h2>
    </div>

    <!-- Content grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">

      <!-- Left: text -->
      <div data-animate class="opacity-0 animate-slide-up">
        <p class="text-slate-300 text-base leading-relaxed mb-4" set:html={t.paragraph1} />
        <p class="text-slate-300 text-base leading-relaxed mb-6" set:html={t.paragraph2} />

        <!-- Stats -->
        <div class="flex gap-8 mt-6">
          <div class="text-center">
            <span class="block text-2xl font-black text-amber-400">2007</span>
            <span class="text-xs text-slate-500 uppercase tracking-wider">{t.year}</span>
          </div>
          <div class="text-center">
            <span class="block text-2xl font-black text-amber-400">Christopher Mintz-Plasse</span>
            <span class="text-xs text-slate-500 uppercase tracking-wider">{t.actor}</span>
          </div>
        </div>
      </div>

      <!-- Right: YouTube facade (iframe loads only on click — no third-party cookies on initial load) -->
      <div
        data-animate
        class="opacity-0 animate-scale-in relative aspect-video rounded-xl overflow-hidden border border-hawaii-steel shadow-xl cursor-pointer group"
        style="animation-delay: 200ms"
        data-yt-facade
        data-video-id={videoId}
        data-video-title={t.videoTitle}
        role="button"
        tabindex="0"
        aria-label={t.videoTitle}
      >
        <img
          src={thumbnailUrl}
          alt={t.videoTitle}
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
          decoding="async"
          width="480"
          height="360"
        />
        <div class="absolute inset-0 flex items-center justify-center bg-black/25 group-hover:bg-black/45 transition-colors">
          <div class="w-16 h-16 rounded-full bg-red-600 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7 text-white ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-yt-facade]').forEach((facade) => {
    const load = () => {
      const videoId = facade.dataset.videoId
      const videoTitle = facade.dataset.videoTitle ?? ''
      const iframe = document.createElement('iframe')
      iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1`
      iframe.title = videoTitle
      iframe.className = 'absolute inset-0 w-full h-full'
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture'
      iframe.allowFullscreen = true
      facade.innerHTML = ''
      facade.removeAttribute('role')
      facade.removeAttribute('tabindex')
      facade.classList.remove('cursor-pointer', 'group')
      facade.appendChild(iframe)
    }

    facade.addEventListener('click', load)
    facade.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault()
        load()
      }
    })
  })
</script>
