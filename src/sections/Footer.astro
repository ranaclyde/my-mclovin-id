---
import Github from '@/icons/github.astro'

const currentYear = new Date().getFullYear()
---

<footer class="mx-auto w-full max-w-screen-lg px-4 py-6 lg:py-8">
  <hr class="my-6 sm:mx-auto border-hawaii-steel lg:my-8" />
  <div class="flex items-center justify-between">
    <span class="text-sm sm:text-center text-slate-500">
      © {currentYear} <a
        href="https://www.linkedin.com/in/emanuel-sanhueza/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:underline hover:text-hawaii-gold-light">Matias Sanhueza</a
      >
    </span>
    <div>
      <a
        href="https://github.com/ranaclyde/my-mclovin-id"
        target="_blank"
        rel="noopener noreferrer"
        class="text-slate-600 hover:text-hawaii-gold-light"
      >
        <Github class="w-4 h-4" />
        <span class="sr-only">GitHub account</span>
      </a>
    </div>
  </div>
</footer>
