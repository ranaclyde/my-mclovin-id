---
import Input from '@/components/ui/Input.astro'
import McLovinCanvas from '@/components/McLovinCanvas.astro'
import Select from '@/components/ui/Select.astro'

import { genresOptions } from '@/const/genres'
import TakePhoto from '@/components/TakePhoto.astro'
import Sign from '@/components/Sign.astro'
import Button from '@/components/ui/Button.astro'
import Download from '@/icons/download.astro'
---

<section id="createid-section" class="bg-hawaii-navy py-16">
  <div class="mx-auto w-full max-w-screen-lg px-4 md:px-6">

    <!-- Section header -->
    <div class="text-center mb-10">
      <span class="inline-block text-xs tracking-[0.3em] uppercase text-hawaii-blue-light border border-hawaii-steel rounded-full px-3 py-1 mb-4">
        Crea tu ID
      </span>
      <h2 class="text-3xl font-bold text-hawaii-gold-light mt-3">
        Personaliza tu documento
      </h2>
      <p class="text-slate-400 mt-2">
        Completá los datos y descargá tu versión del ID de McLovin
      </p>
    </div>

    <!-- Main layout: form left, canvas right on desktop; form on top on mobile -->
    <div class="flex flex-col-reverse md:flex-row gap-6 mb-8">

      <!-- Canvas / Preview column -->
      <div class="w-full md:w-auto flex flex-col items-center gap-4">
        <!-- Mobile static preview -->
        <div class="block md:hidden w-full">
          <img
            src="/images/mclovin-empty-id.webp"
            alt="Preview del ID de McLovin"
            class="w-full max-w-xs mx-auto rounded-lg shadow-lg border border-hawaii-steel opacity-75"
          />
          <p class="text-xs text-slate-500 text-center mt-2">
            Preview interactivo disponible en desktop
          </p>
        </div>
        <!-- Desktop interactive canvas -->
        <McLovinCanvas />
      </div>

      <!-- Form column -->
      <form id="form" class="w-full">
        <Input id="name" label="Nombre" class="mb-5" maxlength="15" />
        <div class="flex gap-3 mb-5">
          <Input id="dob" type="date" label="Fecha de nacimiento" class="flex-auto" />
          <Select id="sex" label="Género" options={genresOptions} />
        </div>
        <TakePhoto />
        <Sign />
      </form>

    </div>

    <!-- Export button -->
    <div class="text-center">
      <Button id="exportCanvas" size="lg" class="min-w-48">
        Exportar ID
        <Download />
      </Button>
    </div>
  </div>
</section>

<script>
  import { $ } from '@/utils/domSelector'

  const $canvas = $<HTMLCanvasElement>('#mclovin-canvas')
  const $exportCanvasButton = $<HTMLButtonElement>('#exportCanvas')

  $exportCanvasButton.onclick = () => {
    $exportCanvasButton.disabled = true

    let downloadLink = document.createElement('a')
    downloadLink.href = $canvas.toDataURL()
    downloadLink.download = 'my-mclovin-id.png'
    downloadLink.click()

    setTimeout(() => {
      $exportCanvasButton.disabled = false
    }, 1000)
  }
</script>
