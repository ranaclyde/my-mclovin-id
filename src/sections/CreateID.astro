---
import Input from '@/components/ui/Input.astro'
import McLovinCanvas from '@/components/McLovinCanvas.astro'
import Select from '@/components/ui/Select.astro'
import TakePhoto from '@/components/TakePhoto.astro'
import Sign from '@/components/Sign.astro'
import Button from '@/components/ui/Button.astro'
import Download from '@/icons/download.astro'
import type { CreateIdTranslations } from '@/i18n/translations'

interface Props {
  t: CreateIdTranslations
}

const { t } = Astro.props
---

<section id="createid-section" class="bg-hawaii-navy py-16">
  <div class="mx-auto w-full max-w-screen-lg px-4 md:px-6">

    <!-- Section header -->
    <div data-animate class="opacity-0 animate-fade-in text-center mb-10">
      <span class="inline-block text-xs tracking-[0.3em] uppercase text-hawaii-blue-light border border-hawaii-steel rounded-full px-3 py-1 mb-4">
        {t.badge}
      </span>
      <h2 class="text-3xl font-bold text-hawaii-gold-light mt-3">
        {t.title}
      </h2>
      <p class="text-slate-400 mt-2">
        {t.subtitle}
      </p>
    </div>

    <!-- Main layout: form left, canvas right on desktop; form on top on mobile -->
    <div class="flex flex-col-reverse md:flex-row gap-6 mb-8">

      <!-- Canvas / Preview column -->
      <div data-animate class="opacity-0 animate-scale-in w-full md:w-auto flex flex-col items-center gap-4">
        <!-- Interactive canvas -->
        <McLovinCanvas />

        <!-- Botón flip, visible solo en md+ (donde el canvas es visible) -->
        <Button
          id="flipCard"
          color="info"
          variant="outlined"
          size="sm"
          class="hidden md:inline-flex"
          data-front={t.flipFront}
          data-back={t.flipBack}
        >
          {t.flipBack}
        </Button>
      </div>

      <!-- Form column -->
      <form id="form" class="w-full">
        <div data-animate class="opacity-0 animate-slide-up" style="animation-delay: 0ms">
          <Input id="name" label={t.name} class="mb-5" maxlength="15" />
        </div>
        <div data-animate class="opacity-0 animate-slide-up" style="animation-delay: 100ms">
          <div class="flex gap-3 mb-5">
            <Input id="dob" type="date" label={t.dob} class="flex-auto" />
            <Select id="sex" label={t.genre} options={t.genres} />
          </div>
        </div>
        <div data-animate class="opacity-0 animate-slide-up" style="animation-delay: 200ms">
          <TakePhoto t={t.photo} />
        </div>
        <div data-animate class="opacity-0 animate-slide-up" style="animation-delay: 300ms">
          <Sign t={t.sign} />
        </div>
      </form>

    </div>

    <!-- Export button -->
    <div class="text-center">
      <Button id="exportCanvas" size="lg" class="min-w-48">
        {t.export}
        <Download />
      </Button>
    </div>
  </div>
</section>

<script>
  import { $ } from '@/utils/domSelector'
  import JSZip from 'jszip'

  const $canvas = $<HTMLCanvasElement>('#mclovin-canvas')
  const $exportCanvasButton = $<HTMLButtonElement>('#exportCanvas')
  const $flipContainer = document.getElementById('flip-container')

  async function exportZip(): Promise<void> {
    $exportCanvasButton.disabled = true
    try {
      const frontDataUrl = $canvas.toDataURL('image/png')
      const base64 = frontDataUrl.split(',')[1]
      const binary = atob(base64)
      const frontBytes = new Uint8Array(binary.length)
      for (let i = 0; i < binary.length; i++) {
        frontBytes[i] = binary.charCodeAt(i)
      }

      const zip = new JSZip()
      zip.file('mclovin-id-front.png', frontBytes)

      try {
        const res = await fetch('/images/mclovin-id-back.webp')
        if (!res.ok) throw new Error(`HTTP ${res.status}`)
        const backBuf = await res.arrayBuffer()
        zip.file('mclovin-id-back.webp', backBuf)
      } catch {
        window.toast?.({
          type: 'warning',
          title: 'Back side skipped',
          message: 'Could not include the ID back. Exporting front only.',
        })
      }

      const blob = await zip.generateAsync({ type: 'blob' })
      const anchor = document.createElement('a')
      const objectUrl = URL.createObjectURL(blob)
      anchor.href = objectUrl
      anchor.download = 'my-mclovin-id.zip'
      anchor.click()
      URL.revokeObjectURL(objectUrl)
    } catch (err) {
      const message = err instanceof Error ? err.message : 'Unknown error'
      window.toast?.({ type: 'error', title: 'Export failed', message })
    } finally {
      if (!$flipContainer?.classList.contains('is-flipped')) {
        $exportCanvasButton.disabled = false
      }
    }
  }

  $exportCanvasButton.onclick = exportZip

  // --- Flip logic ---
  const $flipCard = $<HTMLButtonElement>('#flipCard')

  if ($flipCard && $flipContainer) {
    $flipCard.addEventListener('click', () => {
      const isFlipped = $flipContainer.classList.toggle('is-flipped')
      $flipCard.textContent = isFlipped
        ? ($flipCard.dataset.front ?? '')
        : ($flipCard.dataset.back ?? '')
      $exportCanvasButton.disabled = isFlipped
    })
  }
</script>
